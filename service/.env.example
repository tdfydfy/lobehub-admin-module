PORT=3321
HOST=127.0.0.1
DATABASE_URL=postgresql://lobehub:lobehubpass@127.0.0.1:5432/lobehub
DB_CONNECTION_TIMEOUT_MS=15000
DB_QUERY_TIMEOUT_MS=20000
CORS_ORIGIN=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:4174,http://localhost:4174
ADMIN_SESSION_COOKIE_NAME=lobehub_admin_session
ADMIN_SESSION_TTL_HOURS=12
ADMIN_SESSION_SECURE_COOKIE=false
ALLOW_LEGACY_ACTOR_HEADER=false
TRUST_PROXY=false
PROJECT_DOCS_INTERNAL_TOKEN=
PROJECT_DOCS_PLUGIN_PUBLIC_BASE_URL=
PROJECT_DOCS_PLUGIN_SECRET=
CRM_SUMMARY_SYNC_ENABLED=true
CRM_SUMMARY_SYNC_INTERVAL_MS=5000
CRM_SUMMARY_SYNC_BATCH_SIZE=50
CRM_SUMMARY_SYNC_QUIET_PERIOD_MS=5000
CRM_SUMMARY_SYNC_INITIAL_LOOKBACK_MINUTES=10

# Daily report generation
# Uses the same provider naming as the main LobeHub deployment when available.
DAILY_REPORT_DEFAULT_MODEL_PROVIDER=fallback
# DAILY_REPORT_DEFAULT_MODEL_NAME=doubao-seed-2-0-lite-260215
# VOLCENGINE_API_KEY=your-volcengine-api-key
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional local fallback for old debug flows:
# x-admin-user-id: <user_id>
